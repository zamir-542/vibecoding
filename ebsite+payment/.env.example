# ============================================================
# Environment Variables untuk Sistem Webhook E-book
# ============================================================
# Salin fail ini kepada .env (untuk development tempatan)
# JANGAN commit fail .env ke git!
#
# Untuk production: isi nilai ini di
# Netlify Dashboard > Site Settings > Environment Variables
# ============================================================

# --- Resend API ---
# Dapatkan dari: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- E-mel Penghantar ---
# Mesti domain yang telah disahkan (verified) di Resend
# Untuk test awal, boleh guna: onboarding@resend.dev (Resend built-in)
FROM_EMAIL=noreply@yourdomain.com

# --- Pautan Muat Turun E-book ---
# Letak pautan direct ke fail PDF anda (Google Drive, S3, dll.)
EBOOK_DOWNLOAD_URL=https://example.com/ebook.pdf
